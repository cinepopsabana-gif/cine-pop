# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL: La URL de tu proyecto de Supabase.
# La encuentras en Supabase -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"

# VITE_SUPABASE_ANON_KEY: La clave pública (anon/public) de tu proyecto de Supabase.
# La encuentras en Supabase -> Project Settings -> API -> Project API keys -> anon public
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# VITE_PRINTER_AGENT_URL: URL donde corre el agente local de impresión (print-agent/).
# Por defecto es http://localhost:4000 porque normalmente el navegador de la taquilla
# y el agente corren en la MISMA computadora. Solo cámbialo si el agente corre en otra
# máquina de la red local (ej: http://192.168.1.20:4000).
VITE_PRINTER_AGENT_URL="http://localhost:4000"
