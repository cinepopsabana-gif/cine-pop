# IP de la impresora térmica RPT006 dentro de la red local de la taquilla.
# Para averiguarla: mantén presionado el botón de alimentación de papel (FEED)
# mientras enciendes la impresora -> imprime un ticket de auto-test con la IP.
PRINTER_IP=192.168.1.100

# Puerto de red de la impresora (ESC/POS estándar por LAN, casi siempre 9100)
PRINTER_PORT=9100

# Puerto donde este agente escuchará peticiones de la app web
AGENT_PORT=4000

# Dominio(s) permitidos a llamar a este agente (tu app en Vercel + localhost para pruebas)
# Separa varios con coma si necesitas más de uno.
ALLOWED_ORIGIN=https://cine-pop-ten.vercel.app,http://localhost:3000
